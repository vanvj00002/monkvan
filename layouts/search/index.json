{{- $pages := where .Site.RegularPages "Section" "in" .Site.MainSections -}}
{{- $items := slice -}}
{{- range $pages -}}
  {{- $uri := .RelPermalink -}}
  {{- if $.Site.Params.search.absoluteURL -}}
    {{- $uri = .Permalink -}}
  {{- end -}}
  {{- $obj := dict "title" .Title "permalink" $uri "content" (.Plain | plainify) "tags" .Params.tags "description" .Description "date" (.Date.Format "2006-01-02") -}}
  {{- $items = $items | append $obj -}}
{{- end -}}
{{- $items | jsonify -}}
